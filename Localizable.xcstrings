      }
    },
    "Hand gestures need camera access. Loom reads your palm in real time — open your hand to spread the wall, make a fist to gather it, shake to shuffle. Video is processed frame by frame in memory and never recorded." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Hand gestures need camera access. Loom reads your palm in real time — open your hand to spread the wall, make a fist to gather it, shake to shuffle. Video is processed frame by frame in memory and never recorded." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "手势功能需要摄像头权限。Loom 实时读取你手掌的张开程度——张开手散开墙面,握拳聚拢,晃动手重排。视频在内存里逐帧处理,不会录制保存。" } }
      }
    },
    "You previously declined camera access. macOS won't show the permission dialog again — to use hand gestures you'll need to grant access manually in System Settings." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You previously declined camera access. macOS won't show the permission dialog again — to use hand gestures you'll need to grant access manually in System Settings." } },
