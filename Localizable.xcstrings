    "Loom reads your photos locally to compose aesthetic walls — analysing each one for color and visual similarity so every Shuffle produces a wall that belongs together." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Loom reads your photos locally to compose aesthetic walls — analysing each one for color and visual similarity so every Shuffle produces a wall that belongs together." } },
